CONFIG_CUBESAT_USE_LIBOQS=n
CONFIG_CUBESAT_FAKE_TELEMETRY_ON_GNSS_TIMEOUT=y
CONFIG_CUBESAT_LOG_PACKET_HEX=y
CONFIG_CUBESAT_PIN_STATUS_LED=2
CONFIG_CUBESAT_PIN_LORA_MOSI=23
CONFIG_CUBESAT_PIN_LORA_MISO=19
CONFIG_CUBESAT_PIN_LORA_SCLK=18
CONFIG_CUBESAT_PIN_LORA_CS=5
CONFIG_CUBESAT_PIN_LORA_RESET=14
CONFIG_CUBESAT_PIN_LORA_BUSY=27
CONFIG_CUBESAT_PIN_LORA_DIO1=26
CONFIG_CUBESAT_PIN_GNSS_TX=17
CONFIG_CUBESAT_PIN_GNSS_RX=16
CONFIG_CUBESAT_PIN_I2C_SDA=21
CONFIG_CUBESAT_PIN_I2C_SCL=22
CONFIG_CUBESAT_NODE_ID=1
CONFIG_CUBESAT_GROUND_ID=2
CONFIG_CUBESAT_DEMO_SESSION_ID=0x12345678
CONFIG_CUBESAT_LORA_FREQUENCY_HZ=915000000
CONFIG_CUBESAT_LORA_SPREADING_FACTOR=7
CONFIG_CUBESAT_LORA_BANDWIDTH_HZ=125000
CONFIG_CUBESAT_LORA_CODING_RATE=1
CONFIG_CUBESAT_LORA_TX_POWER_DBM=14
CONFIG_CUBESAT_GNSS_BAUDRATE=9600
