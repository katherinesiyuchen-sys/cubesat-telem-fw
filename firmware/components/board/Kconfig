menu "CubeSat board pins"

config CUBESAT_PIN_STATUS_LED
    int "Status LED GPIO"
    range 0 48
    default 2

config CUBESAT_PIN_LORA_MOSI
    int "SX1262 MOSI GPIO"
    range 0 48
    default 23

config CUBESAT_PIN_LORA_MISO
    int "SX1262 MISO GPIO"
    range 0 48
    default 19

config CUBESAT_PIN_LORA_SCLK
    int "SX1262 SCLK GPIO"
    range 0 48
    default 18

config CUBESAT_PIN_LORA_CS
    int "SX1262 CS/NSS GPIO"
    range 0 48
    default 5

config CUBESAT_PIN_LORA_RESET
    int "SX1262 RESET GPIO"
    range 0 48
    default 14

config CUBESAT_PIN_LORA_BUSY
    int "SX1262 BUSY GPIO"
    range 0 48
    default 27

config CUBESAT_PIN_LORA_DIO1
    int "SX1262 DIO1 GPIO"
    range 0 48
    default 26

config CUBESAT_PIN_GNSS_TX
    int "ESP32 TX GPIO to GNSS RX"
    range 0 48
    default 17

config CUBESAT_PIN_GNSS_RX
    int "ESP32 RX GPIO from GNSS TX"
    range 0 48
    default 16

config CUBESAT_PIN_I2C_SDA
    int "I2C SDA GPIO"
    range 0 48
    default 21

config CUBESAT_PIN_I2C_SCL
    int "I2C SCL GPIO"
    range 0 48
    default 22

config CUBESAT_NODE_ID
    int "CubeSat node ID"
    range 1 65535
    default 1

config CUBESAT_GROUND_ID
    int "Groundstation node ID"
    range 1 65535
    default 2

config CUBESAT_DEMO_SESSION_ID
    hex "Demo session ID"
    default 0x12345678

config CUBESAT_LORA_FREQUENCY_HZ
    int "LoRa frequency in Hz"
    range 100000000 1000000000
    default 915000000

config CUBESAT_GNSS_BAUDRATE
    int "GNSS UART baudrate"
    range 1200 921600
    default 9600

endmenu
