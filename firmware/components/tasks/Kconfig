menu "CubeSat runtime"

config CUBESAT_FAKE_TELEMETRY_ON_GNSS_TIMEOUT
    bool "Transmit bench telemetry when GNSS has no fix"
    default y
    help
        Keeps the ESP32 demo runnable on a desk before the GNSS antenna has a
        valid fix. Disable this for the real GNSS-only milestone.

config CUBESAT_LOG_PACKET_HEX
    bool "Log encoded packet bytes as TX_HEX"
    default y
    help
        Prints each transmitted HOPE packet as a hex line on the ESP32 USB
        console. This is useful for comparing ESP32 output with RangePi serial
        packets.

config CUBESAT_BRINGUP_ONLY
    bool "Run hardware bring-up diagnostics only"
    default n
    help
        Runs the pin/SPI/SX1262/GNSS/I2C/security/NVS diagnostic loop without
        starting the normal telemetry tasks. Enable this while wiring a new
        ESP32 board.

choice CUBESAT_TRANSPORT_MODE
    prompt "Primary packet transport"
    default CUBESAT_TRANSPORT_MODE_LORA
    help
        Selects the packet carrier used by the telemetry task. The HOPE packet
        bytes stay identical; only the carrier changes.

config CUBESAT_TRANSPORT_MODE_LORA
    bool "LoRa SX1262 only"

config CUBESAT_TRANSPORT_MODE_WIFI_UDP
    bool "Wi-Fi UDP only"

config CUBESAT_TRANSPORT_MODE_AUTO
    bool "Auto fallback: LoRa primary, Wi-Fi UDP backup"

config CUBESAT_TRANSPORT_MODE_BLE_RESERVED
    bool "Bluetooth LE reserved"
    help
        Reserved for a future BLE GATT packet service. The current firmware logs
        the selection and falls back to LoRa/Wi-Fi behavior.

endchoice

config CUBESAT_TRANSPORT_AUTO_FAILS
    int "LoRa failures before Wi-Fi fallback"
    range 1 20
    default 3
    depends on CUBESAT_TRANSPORT_MODE_AUTO

endmenu
