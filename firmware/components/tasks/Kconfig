menu "CubeSat runtime"

config CUBESAT_FAKE_TELEMETRY_ON_GNSS_TIMEOUT
    bool "Transmit bench telemetry when GNSS has no fix"
    default y
    help
        Keeps the ESP32 demo runnable on a desk before the GNSS antenna has a
        valid fix. Disable this for the real GNSS-only milestone.

config CUBESAT_LOG_PACKET_HEX
    bool "Log encoded packet bytes as TX_HEX"
    default y
    help
        Prints each transmitted HOPE packet as a hex line on the ESP32 USB
        console. This is useful for comparing ESP32 output with RangePi serial
        packets.

config CUBESAT_BRINGUP_ONLY
    bool "Run hardware bring-up diagnostics only"
    default n
    help
        Runs the pin/SPI/SX1262/GNSS/I2C/security/NVS diagnostic loop without
        starting the normal telemetry tasks. Enable this while wiring a new
        ESP32 board.

endmenu
